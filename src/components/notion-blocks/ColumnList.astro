---
import * as interfaces from '../../lib/interfaces.ts'
import NotionBlocks from '../NotionBlocks.astro'

export interface Props {
  block: interfaces.Block
  headings: interfaces.Block[]
  headingSlugs?: Record<string, string>
}

const { block, headings, headingSlugs } = Astro.props
const columns = block.ColumnList?.Columns ?? []
---

<div class="column-list">
  {
    columns.map((column: interfaces.Column) => (
      <div>
        <NotionBlocks
          blocks={column.Children}
          headings={headings}
          headingSlugs={headingSlugs}
          isRoot={false}
          level={1}
        />
      </div>
    ))
  }
</div>

<style>
  .column-list {
    display: flex;
    width: 100%;
    margin: 1rem auto;
    gap: 0 1rem;
  }
  .column-list > div {
    flex: 1 1 180px;
    width: 180px;
  }
  @media (max-width: 640px) {
    .column-list {
      display: block;
    }
    .column-list > div {
      width: 100%;
    }
  }
</style>
