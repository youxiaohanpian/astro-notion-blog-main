---
/**
 * Mention链接组件
 * 
 * 功能：在文本中创建指向其他Notion页面的链接
 * 
 * 注意事项：
 * 1. 需要通过pageId获取链接的目标页面
 * 2. 样式保持与Notion一致
 * 3. 显示目标页面的图标和标题
 * 4. 当页面不存在时显示提示信息
 * 
 * !!! 警告：此组件已调试正常工作，修改前请确保完全理解其工作原理 !!!
 */
import type { Post, Emoji, FileObject } from '../../lib/interfaces.ts'
import { getPostByPageId } from '../../lib/notion/client'
import { getPostLink } from '../../lib/blog-helpers.ts'
import '../../styles/notion-color.css'
import arrow from '../../images/icon-arrow-link.svg'

export interface Props {
  pageId: string
  label?: string
}

const { pageId, label } = Astro.props

const buildNotionUrl = (rawId: string): string => {
  const normalized = rawId.replace(/-/g, '')
  if (normalized.length !== 32) {
    return ''
  }
  const dashed = `${normalized.slice(0, 8)}-${normalized.slice(8, 12)}-${normalized.slice(12, 16)}-${normalized.slice(16, 20)}-${normalized.slice(20)}`
  return `https://www.notion.so/${dashed}`
}

const fallbackLabel = label && label.trim() !== '' ? label : 'Notion page'

// 获取被提及的页面
let post: Post | null = null
if (pageId && pageId.trim() !== '') {
  try {
    post = await getPostByPageId(pageId)
    // 验证 post 对象是否完整
    if (post && (!post.Slug || !post.PageId)) {
      console.warn(`Mention: Post对象不完整, pageId: ${pageId}, Slug: ${post.Slug}, PageId: ${post.PageId}`)
      post = null
    } else {
      console.log(`Mention: Found post for pageId ${pageId}:`, post ? post.Slug : 'Not found')
    }
  } catch (error) {
    console.error(`Mention: Error fetching post for pageId ${pageId}:`, error)
    post = null
  }
}
---

{
  post && post.Slug && post.Slug.trim() !== '' ? (
    <a href={getPostLink(post.Slug)} class="link">
      <span class="icon">
        {post.Icon ? (
          post.Icon.Type === 'emoji' ? (
            (post.Icon as Emoji).Emoji
          ) : (
            <img
              src={(post.Icon as FileObject).Url}
              class="notion-icon"
              alt="Post title icon in a page link"
            />
          )
        ) : (
          '📄'
        )}
        <img src={arrow.src} class="icon-link" alt="Arrow icon of a page link" />
      </span>
      <span class="text">{post.Title}</span>
    </a>
  ) : (
    <a
      class="link not-found"
      href={pageId ? buildNotionUrl(pageId) : undefined}
      target={pageId ? '_blank' : undefined}
      rel={pageId ? 'noopener noreferrer' : undefined}
    >
      <span class="icon">
        🚫
        <img src={arrow.src} class="icon-link" alt="Arrow icon of a page link" />
      </span>
      <span class="text not-found">{fallbackLabel}</span>
    </a>
  )
}

<style>
  a.link {
    display: inline-flex;
    font-weight: 600;
    gap: 4px;
    color: var(--text-color);
    text-decoration: none;
    border-radius: 3px;
    padding: 0 2px;
    transition: background-color 0.2s;
  }
  a.link:hover {
    background-color: rgba(0, 0, 0, 0.05);
  }
  a.link.not-found {
    cursor: default;
    opacity: 0.7;
  }
  span.icon {
    height: fit-content;
    flex-shrink: 0;
    position: relative;
  }
  span.icon img.notion-icon {
    width: 1.3em;
    height: 1.3rem;
    vertical-align: sub;
    flex-shrink: 0;
    position: relative;
  }
  span.icon img.icon-link {
    display: block;
    position: absolute;
    top: 1em;
    right: 0;
    width: 8px;
    height: 8px;
  }
  span.text {
    color: var(--text-color);
    font-weight: 500;
    text-decoration: underline;
  }
  span.text.not-found {
    font-weight: normal;
    text-decoration: none;
  }
  .mention {
    color: var(--text-color);
  }
</style>
