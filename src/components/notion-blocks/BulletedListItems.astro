---
import * as interfaces from '../../lib/interfaces.ts'
import { snakeToKebab } from '../../lib/style-helpers.ts'
import RichText from './RichText.astro'
import NotionBlocks from '../NotionBlocks.astro'
import '../../styles/notion-color.css'

export interface Props {
  block: interfaces.Block
  headings: interfaces.Block[]
  headingSlugs?: Record<string, string>
}

const { block, headings, headingSlugs } = Astro.props
const listItems = (
  ('ListItems' in block ? block.ListItems : []) as interfaces.Block[]
).filter(
  (item: interfaces.Block): item is interfaces.Block & {
    BulletedListItem: interfaces.BulletedListItem
  } => item.Type === 'bulleted_list_item' && !!item.BulletedListItem
)
---

<ul>
  {
    listItems.map((b) => (
      <li class={snakeToKebab(b.BulletedListItem.Color)}>
        {b.BulletedListItem.RichTexts.map((richText: interfaces.RichText) => (
          <RichText richText={richText} />
        ))}
        {b.HasChildren && b.BulletedListItem.Children && (
          <NotionBlocks
            blocks={b.BulletedListItem.Children}
            headings={headings}
            headingSlugs={headingSlugs}
            isRoot={false}
            level={1}
          />
        )}
      </li>
    ))
  }
</ul>

<style>
  ul {
    font-size: 1rem;
  }
</style>
